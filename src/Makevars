# Build the Go code as a C archive, then link it into the R shared library.

GO = go
GOFLAGS = -buildmode=c-archive

GODIR = go
GOARCHIVE = libdbcgo.a

# cli package provides a C-level progress bar API
CLI_INCLUDE = $(shell $(R_HOME)/bin/Rscript -e "cat(system.file('include', package='cli'))")
PKG_CPPFLAGS = -I$(CLI_INCLUDE)
PKG_LIBS = $(GOARCHIVE) -lresolv

GO_SOURCES = $(wildcard $(GODIR)/*.go) $(GODIR)/go.mod

all: $(SHLIB)

$(SHLIB): $(GOARCHIVE)

$(GOARCHIVE): $(GO_SOURCES)
	cd $(GODIR) && $(GO) build $(GOFLAGS) -o ../$(GOARCHIVE) .

clean:
	rm -f $(GOARCHIVE) libdbcgo.h
